PORT=8510
HOST=0.0.0.0
NODE_ENV=development
APP_VERSION=0.1.0
LOG_LEVEL=info

# JWT — dev uses HS256 symmetric secret; production uses RS256 key pair
JWT_SECRET=dev-secret-change-in-production
# JWT_PRIVATE_KEY=<RSA private key PEM>
# JWT_PUBLIC_KEY=<RSA public key PEM>

# Redis (optional — defaults to redis://localhost:6379 if not set)
REDIS_URL=redis://localhost:6379

# Neo4j — required only if agent-service episodic graph is enabled
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=anwaypassword

# Agent service — episodic graph (Graphiti + Neo4j). Start with:
#   docker compose -f infra/docker-compose.yml up -d agent-service
AGENT_SERVICE_URL=http://localhost:8000

# Database (from M0-T4 Prisma migration) — use localhost when outside Docker, service name when inside
DATABASE_URL=postgresql://anway:anway@localhost:5432/anway

# OTEL — traces sent to OTEL collector (M0-T2 docker-compose)
# Leave unset to disable telemetry (safe for local dev without infra stack)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:8560
OTEL_SERVICE_NAME=anway-gateway

# ── LLM Provider ────────────────────────────────────────────────────────────
# Dev default: Ollama (no API key needed). Run: ollama pull llama3.2:3b
# Or use the demo compose Ollama container (started by start_demo.sh).
OLLAMA_ENDPOINT=http://localhost:11434/v1
OLLAMA_DEFAULT_MODEL=llama3.2:3b

# Production: set one of these instead (comment out OLLAMA_ENDPOINT above)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...
# MISTRAL_API_KEY=...

# OpenAI-compatible endpoint (DeepSeek, Together, etc.)
# OPENAI_BASE_URL=https://api.deepseek.com
# DEEPSEEK_API_KEY=sk-...

# CORS — comma-separated origins, or * for dev
CORS_ORIGIN=http://localhost:8500

# Connector API keys — comma-separated, required for /api/graph/events auth
CONNECTOR_API_KEYS=e2e-key:00000000-0000-0000-0000-000000000001

# Webhook auth — static bearer token for machine senders (Alertmanager, CI, Gitea)
# Must match infra/demo/alertmanager/alertmanager.yml http_config credentials
ANWAY_WEBHOOK_TOKEN=anway-demo-webhook-token
ANWAY_WEBHOOK_TENANT=00000000-0000-0000-0000-000000000001
ANWAY_ENCRYPTION_KEY=BkTBlto29dVJ0bYakarauGAJ4ZJeVC/Lh4fOg6cWTcE=

# OIDC SSO — enable by pointing to Dex (demo compose) or real IdP
# OIDC_ISSUER_URL=http://localhost:5556/dex
# OIDC_CLIENT_ID=anway-demo
# OIDC_CLIENT_SECRET=anway-demo-secret
# OIDC_REDIRECT_URI=http://localhost:4000/auth/oidc/callback
# OIDC_TENANT_ID=00000000-0000-0000-0000-000000000001

# Sentry error tracking — optional, leave unset to disable
# SENTRY_DSN=https://<key>@sentry.io/<project>

# Slack slash commands — optional, leave unset to disable
# SLACK_SIGNING_SECRET=

# dev/e2e only — never set in production
ALLOW_DEV_TOKEN=true

# ── Deploy Agent ─────────────────────────────────────────────────────────────
# Set these to enable real pipeline stage execution (build/deploy/monitor).
# Without them, stages run in DEMO simulation mode.

# Docker registry prefix (e.g. ghcr.io/myorg, 123456789.dkr.ecr.us-east-1.amazonaws.com)
# DOCKER_REGISTRY=ghcr.io/myorg

# Kubernetes credentials for helm deploy and monitor stages
# KUBECONFIG=/home/runner/.kube/config

# Helm config (defaults shown)
# HELM_RELEASE=anway
# HELM_CHART=infra/helm/anway
# HELM_NAMESPACE_STAGING=anway-staging
# HELM_NAMESPACE_PROD=anway

# GitHub Actions trigger (alternative to local docker build)
# GITHUB_TOKEN=ghp_...
# GITHUB_REPO=myorg/anway

# Health check URLs (used by monitor stage when KUBECONFIG not set)
# HEALTH_URL_ANWAY_STAGING=https://anway-staging.yourdomain.com/health/ready
# HEALTH_URL_ANWAY=https://anway.yourdomain.com/health/ready
