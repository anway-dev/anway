# Postgres — use connection_limit and pool_timeout for PgBouncer compatibility
DATABASE_URL=postgresql://user:pass@localhost:5432/anvay?connection_limit=5&pool_timeout=20
DB_POOL_SIZE=5

# Redis — required for multi-pod deployments
REDIS_URL=redis://localhost:6379

# LLM Providers — at least one required
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
OLLAMA_ENDPOINT=http://localhost:11434
LMSTUDIO_ENDPOINT=http://localhost:1234
DEEPSEEK_API_KEY=

# JWT
JWT_SECRET=change-me-in-production

# Encryption key — 32 hex bytes
ENCRYPTION_KEY=

# Connector API keys — format: <key>:<tenantId> (comma-separated)
CONNECTOR_API_KEYS=

# OIDC (optional — skip to use demo auth)
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=
OIDC_TENANT_ID=

# Gateway
GATEWAY_URL=http://localhost:4000
PORT=4000
HOST=0.0.0.0
