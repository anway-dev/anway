# Infra service defaults (no API keys — configure those in the web UI)
POSTGRES_USER=anvay
POSTGRES_PASSWORD=anvay
POSTGRES_DB=anvay

# Application URLs — use localhost when gateway runs outside Docker (pnpm dev)
# Use service names when gateway runs inside Docker Compose:
#   DATABASE_URL=postgresql://anvay:anvay@postgres:5432/anvay
#   REDIS_URL=redis://redis:6379
DATABASE_URL=postgresql://anvay:anvay@localhost:5432/anvay
REDIS_URL=redis://localhost:6379
