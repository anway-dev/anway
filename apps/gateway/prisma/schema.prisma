generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  tier1
  tier2
  tier3
}

enum AgentRole {
  sre
  dev
  pm
  ba
  admin
}

enum ConnectorMode {
  read
  write
  read_write
}

enum IncidentSeverity {
  critical
  high
  medium
  low
}

enum IncidentStatus {
  active
  investigating
  resolved
}

model Tenant {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String
  slug                 String   @unique
  plan                 Plan     @default(tier1)
  token_budget_monthly    Int?
  per_query_token_limit   Int?
  per_session_token_limit Int?
  connector_limit         Int      @default(3)
  created_at           DateTime @default(now()) @db.Timestamptz

  users            User[]
  sessions         Session[]
  connectors       Connector[]
  incidents        Incident[]
  audit_events     AuditEvent[]
  providerConfig   ProviderConfig?
  connectorConfigs ConnectorConfig[]

  @@map("tenants")
}

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id     String    @db.Uuid
  email         String
  role          AgentRole @default(dev)
  password_hash String?
  oidc_sub      String?
  created_at    DateTime  @default(now()) @db.Timestamptz

  tenant       Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  sessions     Session[]
  audit_events AuditEvent[]

  @@unique([tenant_id, email])
  @@index([tenant_id])
  @@index([oidc_sub])
  @@map("users")
}

model Session {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  tenant_id  String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz
  expires_at DateTime @db.Timestamptz
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz
  turn_count Int      @default(0) @map("turn_count")

  user   User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([user_id])
  @@map("sessions")
}

model Connector {
  id                  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id           String        @db.Uuid
  name                String
  type                String
  mode                ConnectorMode @default(read)
  config_enc          String?
  capability_manifest Json          @default("{}")
  created_at          DateTime      @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@map("connectors")
}

model AuditEvent {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String   @db.Uuid
  user_id    String?  @db.Uuid
  session_id String?  @db.Uuid
  event_type String
  payload    Json     @default("{}")
  created_at DateTime @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([tenant_id])
  @@index([tenant_id, created_at])
  @@map("audit_events")
}

model Incident {
  id                   String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id            String           @db.Uuid
  title                String
  severity             IncidentSeverity @default(medium)
  status               IncidentStatus   @default(active)
  description          String?
  suggested_root_cause String?
  created_at           DateTime         @default(now()) @db.Timestamptz
  resolved_at          DateTime?        @db.Timestamptz

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([tenant_id, status])
  @@map("incidents")
}

model ProviderConfig {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id     String   @db.Uuid
  provider      String   @db.VarChar(50)
  base_url      String?  @db.Text
  default_model String?  @db.VarChar(100)
  cheap_model   String?  @db.VarChar(100)
  api_key_enc   String?  @db.Text
  updated_at    DateTime @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id])
  @@map("provider_config")
}

model ConnectorConfig {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id              String    @db.Uuid
  connector_type         String    @db.VarChar(50)
  // Distinguishes multiple instances of the same connector_type for the same
  // tenant (e.g. two separate MCP-backed connectors). Defaults to
  // connector_type for singleton native connectors — see migration 0046.
  // Real unique index (with env_id folded via COALESCE) is a raw-SQL
  // functional index Prisma can't express directly; @@unique below omits
  // env_id to match the pre-existing pattern in this model.
  instance_name          String    @db.VarChar(100)
  // credentials Json field dropped by migration 0024 — use credentials_enc instead
  credentials_enc        String?   @db.Text
  enabled                Boolean   @default(false)
  bootstrapped_at        DateTime? @db.Timestamptz
  last_bootstrap_summary Json?     @default("{}")
  updated_at             DateTime  @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, connector_type, instance_name])
  @@map("connector_config")
}
