# Infra service defaults (no API keys — configure those in the web UI)
POSTGRES_USER=anway
POSTGRES_PASSWORD=anway
POSTGRES_DB=anway

# Application URLs — use localhost when gateway runs outside Docker (pnpm dev)
# Use service names when gateway runs inside Docker Compose:
#   DATABASE_URL=postgresql://anway:anway@postgres:5432/anway
#   REDIS_URL=redis://redis:6379
DATABASE_URL=postgresql://anway:anway@localhost:5432/anway
REDIS_URL=redis://localhost:6379
